        },
        {
          "title": "Ward Information",
          "fields": [
            {"name": "aip_residence", "label": "Ward's county of residence", "type": "text"},
            {"name": "ward_incapacity_nature", "label": "Nature and extent of ward's incapacity", "type": "textarea"}
          ]
        },
        {
          "title": "Proposed Guardian",
          "fields": [
            {"name": "proposed_guardian_name", "label": "Proposed guardian's name", "type": "text"},
            {"name": "proposed_guardian_residence", "label": "Proposed guardian's county of residence", "type": "text"},
            {"name": "proposed_guardian_address", "label": "Proposed guardian's post office address", "type": "text"},
            {"name": "proposed_guardian_professional", "label": "Professional guardian?", "type": "checkbox"},
            {"name": "proposed_guardian_relationship", "label": "Relationship to ward", "type": "text"}
          ]
        },
        {
          "title": "Property",
          "fields": [
            {"name": "property_description", "label": "Description of property subject to guardianship", "type": "textarea"}
          ]
        },
        {
          "title": "Alternatives and Appointment",
          "fields": [
            {"name": "alternatives_description", "label": "Alternatives to guardianship considered", "type": "textarea"},
            {"name": "alternatives_insufficient_reason", "label": "Why alternatives are insufficient", "type": "textarea"},
            {"name": "has_preneed", "label": "Ward has designated a preneed guardian", "type": "checkbox"},
            {"name": "appointment_reason", "label": "Reason for appointing proposed guardian", "type": "textarea"}
          ]
        },
        {
          "title": "Next of Kin",
          "fields": [
            {
              "name": "next_of_kin",
              "label": "Next of kin of the ward",
              "type": "repeating_group",
              "subfields": [
                {"name": "name", "label": "Name", "type": "text"},
                {"name": "address", "label": "Address", "type": "text"},
                {"name": "relationship", "label": "Relationship", "type": "text"}
              ]
            }
          ]
        },
        {
          "title": "Signing Information",
          "fields": [
            {"name": "signing_day", "label": "Day", "type": "text"},
            {"name": "signing_month", "label": "Month", "type": "text"},
            {"name": "signing_year", "label": "Year", "type": "text"}
          ]
        }
      ]
    },
    {
      "id": "G3-026",
      "name": "Petition for Appointment of Limited Guardian of Person and Property",
      "template": "templates/G3-026.docx",
      "sections": [
        {
          "title": "Petitioner Information",
          "fields": [
            {"name": "petitioner_residence", "label": "Petitioner's county of residence", "type": "text"}
          ]
        },
        {
          "title": "Ward Information",
          "fields": [
            {"name": "aip_residence", "label": "Ward's county of residence", "type": "text"}
          ]
        },
        {
          "title": "Rights to Remove from Ward",
          "fields": [
            {"name": "remove_marry", "label": "To marry", "type": "checkbox"},
            {"name": "remove_vote", "label": "To vote", "type": "checkbox"},
            {"name": "remove_govt_benefits", "label": "To apply for government benefits", "type": "checkbox"},
            {"name": "remove_drivers_license", "label": "To have a driver's license", "type": "checkbox"},
            {"name": "remove_travel", "label": "To travel", "type": "checkbox"},
            {"name": "remove_employment", "label": "To seek or retain employment", "type": "checkbox"}
          ]
        },
        {
          "title": "Rights to Delegate to Guardian",
          "fields": [
            {"name": "delegate_contract", "label": "To contract", "type": "checkbox"},
            {"name": "delegate_sue", "label": "To sue and defend lawsuits", "type": "checkbox"},
            {"name": "delegate_govt_benefits", "label": "To apply for government benefits", "type": "checkbox"},
            {"name": "delegate_property", "label": "To manage property", "type": "checkbox"},
            {"name": "delegate_residence", "label": "To determine residence", "type": "checkbox"},
            {"name": "delegate_medical", "label": "To consent to medical treatment", "type": "checkbox"},
            {"name": "delegate_social", "label": "To make decisions about social environment", "type": "checkbox"}
          ]
        },
        {
          "title": "Property",
          "fields": [
            {"name": "property_value_description", "label": "Nature and value of property subject to guardianship", "type": "textarea"},
            {"name": "incapable_property", "label": "Description of property ward is incapable of managing", "type": "textarea"}
          ]
        },
        {
          "title": "Proposed Guardian",
          "fields": [
            {"name": "proposed_guardian_name", "label": "Proposed guardian's name", "type": "text"},
            {"name": "proposed_guardian_residence", "label": "Proposed guardian's county of residence", "type": "text"},
            {"name": "proposed_guardian_address", "label": "Proposed guardian's post office address", "type": "text"},
            {"name": "proposed_guardian_professional", "label": "Professional guardian?", "type": "checkbox"},
            {"name": "proposed_guardian_pronoun", "label": "Proposed guardian's pronoun (he/she/they)", "type": "text"},
            {"name": "proposed_guardian_relationship", "label": "Relationship to ward", "type": "text"}
          ]
        },
        {
          "title": "Alternatives and Appointment",
          "fields": [
            {"name": "has_alternatives", "label": "Ward has executed documents (advance directives, etc.)", "type": "checkbox"},
            {"name": "alternatives_description", "label": "Description of alternatives considered", "type": "textarea"},
            {"name": "has_preneed", "label": "Ward has designated a preneed guardian", "type": "checkbox"},
            {"name": "appointment_reason", "label": "Reason for appointing proposed guardian", "type": "textarea"}
          ]
        },
        {
          "title": "Next of Kin",
          "fields": [
            {
              "name": "next_of_kin",
              "label": "Next of kin of the ward",
              "type": "repeating_group",
              "subfields": [
                {"name": "name", "label": "Name", "type": "text"},
                {"name": "address", "label": "Address", "type": "text"},
                {"name": "relationship", "label": "Relationship", "type": "text"}
              ]
            }
          ]
        },
        {
          "title": "Signing Information",
          "fields": [
            {"name": "signing_day", "label": "Day", "type": "text"},
            {"name": "signing_month", "label": "Month", "type": "text"},
